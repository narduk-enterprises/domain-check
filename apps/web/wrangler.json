{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "domain-check",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "f1babe15848440bd97a47d1f7d514681",
      "preview_id": "9bdd8ba5daad451c88d6c06f6cac5f95"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "domain-check-db",
      "database_id": "8d19adcd-2a9f-47f7-9e6d-9593be32f813"
    }
  ],
  "ratelimits": [
    {
      "name": "RL_10",
      "namespace_id": "50110",
      "simple": {
        "limit": 10,
        "period": 60
      }
    },
    {
      "name": "RL_20",
      "namespace_id": "50120",
      "simple": {
        "limit": 20,
        "period": 60
      }
    },
    {
      "name": "RL_30",
      "namespace_id": "50130",
      "simple": {
        "limit": 30,
        "period": 60
      }
    },
    {
      "name": "RL_60",
      "namespace_id": "50160",
      "simple": {
        "limit": 60,
        "period": 60
      }
    },
    {
      "name": "RL_120",
      "namespace_id": "50121",
      "simple": {
        "limit": 120,
        "period": 60
      }
    },
    {
      "name": "RL_240",
      "namespace_id": "50240",
      "simple": {
        "limit": 240,
        "period": 60
      }
    },
    {
      "name": "RL_300",
      "namespace_id": "50300",
      "simple": {
        "limit": 300,
        "period": 60
      }
    }
  ],
  "env": {
    "postgres": {
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": ""
        }
      ]
    }
  },
  "routes": [
    {
      "pattern": "domain-check.nard.uk",
      "custom_domain": true
    }
  ]
}
